#!/usr/bin/env sh
# Block local-only files from ever being committed.
# These are intentionally untracked (see .gitignore) and should never
# land in the repo even if someone runs `git add -f` by mistake.
LOCAL_ONLY='^(CLAUDE\.md|about-yuku\.md|\.claude/)'
# Only block adds and modifies; allow deletes so files can be untracked.
STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E "$LOCAL_ONLY" || true)
if [ -n "$STAGED" ]; then
  echo ""
  echo "  Refusing to commit local-only file(s):"
  printf '    %s\n' $STAGED
  echo ""
  echo "  These files are listed in .gitignore and must stay local."
  echo "  If you REALLY need to commit one, bypass with: git commit --no-verify"
  echo ""
  exit 1
fi

# Block accidental reintroduction of Unsplash URLs.
# Spec: docs/superpowers/specs/2026-04-11-unsplash-removal-design.md
# fill-photo-gaps.js and enrich-all-locations.js intentionally contain
# unsplash detection regex — skip them along with docs and memory.
UNSPLASH_STAGED=$(git diff --cached --name-only --diff-filter=AM \
  | grep -vE '^(docs/|memory/|\.husky/|\.github/workflows/|scripts/(fill-photo-gaps\.js|enrich-all-locations\.js|clean-unsplash-urls\.ts)$)' \
  | (while IFS= read -r f; do
      if [ -f "$f" ] && grep -q "images\.unsplash\.com" "$f" 2>/dev/null; then
        echo "$f"
      fi
    done) || true)
if [ -n "$UNSPLASH_STAGED" ]; then
  echo ""
  echo "  Unsplash URLs found in staged files:"
  printf '    %s\n' $UNSPLASH_STAGED
  echo ""
  echo "  This app no longer uses Unsplash. See:"
  echo "    docs/superpowers/specs/2026-04-11-unsplash-removal-design.md"
  echo ""
  exit 1
fi

npx lint-staged

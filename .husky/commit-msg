#!/bin/sh

# Block AI tool/vendor references in commit messages
MSG=$(cat "$1")

# Check for AI tool names (case-insensitive)
if echo "$MSG" | grep -iqE '\b(claude|anthropic|gemini|openai|chatgpt|copilot)\b'; then
  echo ""
  echo "ERROR: Commit message contains AI tool references."
  echo "Blocked terms: Claude, Anthropic, Gemini, OpenAI, ChatGPT, Copilot"
  echo "Reword your commit message to remove these references."
  echo ""
  exit 1
fi

# Check for LLM acronym
if echo "$MSG" | grep -qE '\bLLM\b'; then
  echo ""
  echo "ERROR: Commit message contains 'LLM'."
  echo "Use 'generation', 'smart', or 'AI' instead."
  echo ""
  exit 1
fi

# Check for internal config file references
if echo "$MSG" | grep -iqE 'CLAUDE\.md|\.claudedoc|\.clauderules'; then
  echo ""
  echo "ERROR: Commit message references internal config files."
  echo "Use 'project docs' or 'project config' instead."
  echo ""
  exit 1
fi
